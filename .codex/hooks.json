{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$(git rev-parse --show-toplevel)/.codex/hooks/format_and_test.py\"",
            "statusMessage": "Formatting Python and running tests",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
