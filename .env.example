STRAVA_CLIENT_ID=your-client-id
STRAVA_CLIENT_SECRET=your-client-secret
STRAVA_REDIRECT_URI=http://localhost/exchange_token

TELEGRAM_BOT_TOKEN=123456:your-telegram-bot-token
# Optional: lock the bot to one chat. If omitted, the first chat to message the bot is saved.
TELEGRAM_CHAT_ID=

# Optional, but recommended for natural coaching chat.
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-5.4-mini
